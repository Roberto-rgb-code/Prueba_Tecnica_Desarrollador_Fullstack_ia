{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "MongoDb": {
    "ConnectionString": "mongodb://mongodb:27017",
    "DatabaseName": "TokaAudit",
    "CollectionName": "audit_logs",
    "UseMongo": true
  },
  "Jwt": {
    "Issuer": "toka-auth",
    "Audience": "toka-services",
    "SecretKey": "TokaSuperSecretKeyForJwtTokens2024!MustBeLongEnough",
    "ExpirationMinutes": 60
  },
  "RabbitMq": {
    "Host": "rabbitmq",
    "Username": "guest",
    "Password": "guest",
    "ExchangeName": "toka.events"
  },
  "Messaging": { "UseRabbitMq": true }
}
