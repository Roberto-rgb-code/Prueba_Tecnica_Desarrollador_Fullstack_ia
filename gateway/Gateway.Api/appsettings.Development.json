{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/api/auth/{**catch-all}" }
      },
      "users-route": {
        "ClusterId": "users-cluster",
        "Match": { "Path": "/api/users/{**catch-all}" }
      },
      "users-root": {
        "ClusterId": "users-cluster",
        "Match": { "Path": "/api/users" }
      },
      "roles-route": {
        "ClusterId": "roles-cluster",
        "Match": { "Path": "/api/roles/{**catch-all}" }
      },
      "roles-root": {
        "ClusterId": "roles-cluster",
        "Match": { "Path": "/api/roles" }
      },
      "audit-route": {
        "ClusterId": "audit-cluster",
        "Match": { "Path": "/api/audit/{**catch-all}" }
      },
      "audit-root": {
        "ClusterId": "audit-cluster",
        "Match": { "Path": "/api/audit" }
      },
      "agent-route": {
        "ClusterId": "agent-cluster",
        "Match": { "Path": "/api/agent/{**catch-all}" }
      }
    },
    "Clusters": {
      "auth-cluster": { "Destinations": { "auth": { "Address": "http://localhost:5172" } } },
      "users-cluster": { "Destinations": { "users": { "Address": "http://localhost:5085" } } },
      "roles-cluster": { "Destinations": { "roles": { "Address": "http://localhost:5169" } } },
      "audit-cluster": { "Destinations": { "audit": { "Address": "http://localhost:5195" } } },
      "agent-cluster": { "Destinations": { "agent": { "Address": "http://localhost:5180" } } }
    }
  }
}
